# Normalize line endings: store as LF in the repo, let Git convert on
# checkout per platform. Keeps diffs clean across Windows/macOS/Linux.
* text=auto

# Source and doc files we know are text
*.pl   text
*.py   text
*.sql  text
*.md   text
*.txt  text
LICENSE text

# Windows-specific scripts (if ever added) should keep CRLF
*.bat  text eol=crlf
*.ps1  text eol=crlf

# Binary files (if ever added) -- never touch line endings
*.png  binary
*.jpg  binary
*.pdf  binary
*.docx binary
